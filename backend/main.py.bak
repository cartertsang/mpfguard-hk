from fastapi import FastAPI
from app.core.config import settings
from app.services.mpf_calculator import calculate_mpf, PayrollInput
from fastapi.middleware.cors import CORSMiddleware

app = FastAPI(title="MPFGuard HK MVP")

from app.core.security import require_user
app.middleware("http")(
    lambda request, call_next:
        if "Authorization" not in request.headers:
            return JSONResponse({"error": "Auth required"}, 401)
        call_next(request)
)

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],  # Test only
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

@app.post("/api/v1/mpf/calculate")
async def api_calc_mpf(payroll: PayrollInput):
    result = calculate_mpf(payroll)
    return result

@app.get("/health")
async def health():
    return {"status": "healthy", "mpf_params": vars(settings)}

if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=8001)